{
  "expo": {
    "name": "Kavi ki Vidya",
    "slug": "kavi-ki-vidya",
    "scheme": "kavi-ki-vidya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Kavi ki Vidya uses the microphone so you can practice speaking English with the AI coach."
      },
      "bitcode": false,
      "bundleIdentifier": "com.anonymous.kavi-ki-vidya"
    },
    "android": {
      "package": "com.kavikividya.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Kavi ki Vidya uses the microphone so you can practice speaking English with the AI coach.",
          "recordAudioAndroid": true
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "microphonePermission": "Kavi ki Vidya uses the microphone so you can practice live English conversations with the AI coach."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8beb355b-0b3a-4d06-b863-2b7296635b90"
      }
    },
    "owner": "nileshgajwani"
  }
}
