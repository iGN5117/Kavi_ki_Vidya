OPENAI_API_KEY=your_openai_api_key_here
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_AUDIO_ASSESSMENT_MODEL=gpt-audio-1.5
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_TTS_INSTRUCTIONS=Speak as a warm Indian English woman coach for adult learners. Use a calm, clear, natural Indian English accent, medium-slow pace, and gentle encouragement. Do not exaggerate the accent.
PRONUNCIATION_TRANSCRIPT_WEIGHT=0.08
PRONUNCIATION_CLEAR_THRESHOLD=90
PRONUNCIATION_PRACTICE_THRESHOLD=70
PRONUNCIATION_MIN_CLARITY_FOR_CLEAR=86
PRONUNCIATION_MIN_SOUND_FOR_CLEAR=86
PRONUNCIATION_MIN_RHYTHM_FOR_CLEAR=78
PRONUNCIATION_MIN_RHYTHM_HARD_FLOOR=62
PRONUNCIATION_COMPONENT_TOLERANCE=4
PORT=8787
PROGRESS_STORAGE_PROVIDER=file-json
# Optional production-shaped progress storage. Keep these server-only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROGRESS_TABLE=learner_progress
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787/api
EXPO_PUBLIC_REALTIME_SESSION_ENDPOINT=http://localhost:8787/api/realtime/session
EXPO_PUBLIC_SYNC_PROFILE_ID=local-kavita
RENDER_SERVICE_URL=https://kavi-ki-vidya-api.onrender.com
RENDER_DEPLOY_HOOK_URL=
RENDER_API_KEY=
RENDER_SERVICE_ID=
