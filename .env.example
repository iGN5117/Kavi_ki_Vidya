SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROGRESS_TABLE=learner_progress
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787/api
EXPO_PUBLIC_REALTIME_SESSION_ENDPOINT=http://localhost:8787/api/realtime/session
EXPO_PUBLIC_SYNC_PROFILE_ID=local-kavita
